# PostgreSQL connection string (local docker-compose default shown)
DATABASE_URL="postgresql://mizaly:mizaly@localhost:5433/mizaly?schema=public"

# Auth secrets - generate random strings, do not commit real values
JWT_SECRET=
JWT_REFRESH_SECRET=

# Server
PORT=4000
BACKEND_PUBLIC_URL=http://localhost:4000
MOBILE_APP_URL=http://localhost:5173

# Zernio (social media API - zernio.com)
# Zernio caps each key at 2 connected accounts. ZERNIO_API_KEY_1 is key "1" -
# add ZERNIO_API_KEY_2, ZERNIO_API_KEY_3, ... for more; they're auto-detected
# and assignable per user from the admin panel's Organization tab (see
# apps/backend/src/integrations/zernioApiKeys.ts).
ZERNIO_API_KEY_1=
ZERNIO_API_KEY_2=
ZERNIO_WEBHOOK_SECRET=

# OpenAI (AI caption generation, content classification)
OPENAI_API_KEY=

# Apify (legacy Instagram scraping - superseded by SCRAPE_DO_KEY below, kept
# for now, see integrations/apify.ts)
APIFY_API_KEY=

# Scrape.do (Instagram scraping for the Inspiracje tab - see
# apps/instagram-scraper and integrations/instagramScraper.ts)
SCRAPE_DO_KEY=
# Set to "true" to also fetch every comment on a post the first time it's
# scraped (opt-in - full comment pagination costs several extra Scrape.do
# requests per post). Never re-fetched for a post already in the DB.
INSTAGRAM_FETCH_COMMENTS=

# Newsletter inbox (IMAP, read-only) - see integrations/mail.ts
MAIL_IMAP_HOST=
MAIL_IMAP_PORT=993
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_USER=
MAIL_PASSWORD=

# Cloudinary (media upload for posts/reels - needs a public URL for Zernio)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudflare R2 (Instagram/Reels media storage for Inspiracje - see
# lib/r2Store.ts). Note: R2 has separate, incompatible endpoints per
# jurisdiction (e.g. plain vs ".eu." - use whichever your bucket actually
# lives under, a mismatch gives a misleading NoSuchBucket error).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=
R2_TOKEN_VALUE=
