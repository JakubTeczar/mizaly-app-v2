# PostgreSQL connection string (local docker-compose default shown)
DATABASE_URL="postgresql://mizaly:mizaly@localhost:5433/mizaly?schema=public"

# Auth secrets - generate random strings, do not commit real values
JWT_SECRET=
JWT_REFRESH_SECRET=

# Server
PORT=4000
BACKEND_PUBLIC_URL=http://localhost:4000
MOBILE_APP_URL=http://localhost:5173

# Zernio (social media API - zernio.com)
# Zernio caps each key at 2 connected accounts. ZERNIO_API_KEY (or
# ZERNIO_API_KEY_1) is key "1" - add ZERNIO_API_KEY_2, ZERNIO_API_KEY_3, ...
# for more; they're auto-detected and assignable per user from the admin
# panel's Organization tab (see apps/backend/src/integrations/zernioApiKeys.ts).
ZERNIO_API_KEY=
ZERNIO_API_KEY_2=
ZERNIO_WEBHOOK_SECRET=

# OpenAI (AI caption generation)
OPENAI_API_KEY=

# Apify (Instagram scraping for the Inspiracje tab)
APIFY_API_KEY=

# Cloudinary (media upload for posts/reels - needs a public URL for Zernio)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
