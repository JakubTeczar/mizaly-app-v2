{
  "$schema": "https://schema.railpack.com",
  "buildAptPackages": ["python3", "python3-pip", "ffmpeg", "chromium"],
  "steps": {
    "install": {
      "commands": [
        "yarn install --ignore-scripts --frozen-lockfile",
        "node node_modules/yt-dlp-exec/scripts/postinstall.js || true",
        "pip3 install --break-system-packages -r apps/instagram-scraper/requirements.txt"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["yarn workspace @mizaly/backend build"]
    }
  },
  "deploy": {
    "startCommand": "export PUPPETEER_EXECUTABLE_PATH=$(which chromium) && node node_modules/prisma/build/index.js migrate deploy --schema apps/backend/prisma/schema.prisma && node apps/backend/dist/index.js"
  }
}
