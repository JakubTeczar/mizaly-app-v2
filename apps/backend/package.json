{
  "name": "@mizaly/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/media/assets', 'dist/media/assets', { recursive: true }); require('fs').cpSync('src/media/templates', 'dist/media/templates', { recursive: true })\"",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "backfill:analysis": "tsx src/scripts/backfillContentAnalysis.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@smithy/node-http-handler": "^4.9.5",
    "@mizaly/shared": "0.1.0",
    "@prisma/client": "^5.19.1",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "imapflow": "^1.4.6",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.14",
    "openai": "^4.63.0",
    "puppeteer": "^23.6.0",
    "sanitize-html": "^2.17.5",
    "socket.io": "^4.7.5",
    "yt-dlp-exec": "^1.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.14.15",
    "@types/sanitize-html": "^2.16.1",
    "prisma": "^5.19.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
