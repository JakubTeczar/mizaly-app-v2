# --- External APIs (dostarczone) ---
# Zernio caps each key at 2 połączone konta. ZERNIO_API_KEY (lub ZERNIO_API_KEY_1)
# to klucz "1" - dodaj ZERNIO_API_KEY_2, ZERNIO_API_KEY_3, ... dla kolejnych;
# są wykrywane automatycznie i przypisywalne per użytkownik w panelu admina.
ZERNIO_API_KEY=
ZERNIO_API_KEY_2=
OPENAI_API_KEY=
APIFY_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Newsletter mailbox (Inspiracje > Newsletter, src/integrations/mail.ts) ---
MAIL_IMAP_HOST=
MAIL_IMAP_PORT=993
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_USER=
MAIL_PASSWORD=

# --- Backend ---
DATABASE_URL="postgresql://mizaly:mizaly@localhost:5433/mizaly?schema=public"
JWT_SECRET=
JWT_REFRESH_SECRET=
PORT=4000
BACKEND_PUBLIC_URL=http://localhost:4000
MOBILE_APP_URL=http://localhost:5173

# --- Zernio webhooks (uzupełnić przy konfiguracji integracji) ---
ZERNIO_WEBHOOK_SECRET=

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:4000
